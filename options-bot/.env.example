# ═══════════════════════════════════════════════════════════════
# Options Bot Environment Configuration
# Copy this file to .env and fill in your credentials
# ═══════════════════════════════════════════════════════════════

# ── Alpaca (Required) ────────────────────────────────────────
# Get keys from: https://app.alpaca.markets → API Keys
# Requires Algo Trader Plus plan ($99/mo) for real-time SIP data
ALPACA_API_KEY=your_key_here
ALPACA_API_SECRET=your_secret_here
ALPACA_PAPER=true

# ── Theta Data (Required for training) ──────────────────────
# Get credentials from: https://www.thetadata.net
# Requires Options Standard plan (~$30/mo)
THETADATA_USERNAME=your_email@example.com
THETADATA_PASSWORD=your_password_here

# ── Theta Terminal Connection (Optional — defaults shown) ───
# Only change if Theta Terminal runs on a different host/port
# THETA_TERMINAL_HOST=127.0.0.1
# THETA_TERMINAL_PORT=25503

# ── Logging (Optional) ──────────────────────────────────────
# LOG_LEVEL=INFO
